# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored — never commit it.

# Required: Git repository URL to clone onto EC2
git_repo_url = "https://github.com/your-org/proj_days.git"

# Optional: Git branch
# git_branch = "master"

# Required: RDS master password (min 8 chars)
db_password = "change-me-strong-password"

# Required: Secret key for session cookie signing (random string, min 32 chars)
session_secret = "change-me-random-secret-key-at-least-32-chars"

# Optional: Application login password (default: inha-nxt)
# app_password = "inha-nxt"

# Optional: AWS region (default: ap-northeast-2)
# aws_region = "ap-northeast-2"

# Optional: Bedrock model ID (default: global.anthropic.claude-sonnet-4-6)
# bedrock_model_id = "global.anthropic.claude-sonnet-4-6"

# Required for push notifications: VAPID key pair
# Generate with: npx web-push generate-vapid-keys
vapid_public_key  = "BYour87CharBase64UrlPublicKeyHere..."
vapid_private_key = "base64EncodedPEMPrivateKeyHere..."
vapid_subject     = "mailto:your@email.com"

# Required in production (HTTPS via CloudFront)
cookie_secure = true
