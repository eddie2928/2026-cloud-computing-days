# Terraform
infra/.terraform/
infra/*.tfstate*
infra/*.tfplan
infra/terraform.tfvars
infra/*.pem
# Catch-all in case terraform is run from another cwd (e.g. project root)
**/*.tfstate
**/*.tfstate.*
**/.terraform/
**/*.tfplan

# Python
backend/.venv/
backend/__pycache__/
**/__pycache__/
**/*.pyc
backend/.pytest_cache/
backend/.coverage

# Node
frontend/node_modules/
frontend/dist/

# Environment (allow *.example files)
.env
.env.*
!.env.example
!**/.env.example

Task*.md